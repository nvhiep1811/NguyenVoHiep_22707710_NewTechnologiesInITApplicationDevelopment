<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý sản phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-4">
        <h1 class="mb-4 text-center">Quản lý sản phẩm</h1>

        <div class="card mb-4">
            <div class="card-header">
                <strong><%= editProduct ? 'Cập nhật sản phẩm' : 'Thêm sản phẩm' %></strong>
            </div>
            <div class="card-body">
                <form action="<%= editProduct ? `/products/update/${editProduct.id}` : '/products' %>" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="name" class="form-label">Tên sản phẩm</label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            class="form-control"
                            value="<%= editProduct ? editProduct.name : '' %>"
                            required
                        >
                    </div>

                    <div class="mb-3">
                        <label for="price" class="form-label">Giá</label>
                        <input
                            type="number"
                            id="price"
                            name="price"
                            class="form-control"
                            value="<%= editProduct ? editProduct.price : '' %>"
                            required
                        >
                    </div>

                    <div class="mb-3">
                        <label for="image" class="form-label">Hình ảnh</label>
                        <input
                            type="file"
                            id="image"
                            name="image"
                            class="form-control"
                            accept="image/*"
                            <%= editProduct ? '' : 'required' %>
                        >
                    </div>

                    <% if (editProduct && editProduct.image) { %>
                        <div class="mb-3">
                            <p class="mb-2">Hình hiện tại:</p>
                            <img src="<%= editProduct.image %>" alt="<%= editProduct.name %>" class="img-thumbnail" style="max-width: 120px;">
                        </div>
                    <% } %>

                    <button type="submit" class="btn btn-primary">
                        <%= editProduct ? 'Cập nhật' : 'Thêm mới' %>
                    </button>

                    <% if (editProduct) { %>
                        <a href="/products" class="btn btn-secondary">Hủy</a>
                    <% } %>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <strong>Danh sách sản phẩm</strong>
            </div>
            <div class="card-body p-0">
                <% if (products && products.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Hình ảnh</th>
                                    <th>Tên sản phẩm</th>
                                    <th>Giá</th>
                                    <th style="width: 180px;">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% products.forEach(product => { %>
                                    <tr>
                                        <td><%= product.id %></td>
                                        <td>
                                            <% if (product.image) { %>
                                                <img src="<%= product.image %>" alt="<%= product.name %>" class="img-thumbnail" style="max-width: 80px;">
                                            <% } else { %>
                                                <span class="text-muted">Không có</span>
                                            <% } %>
                                        </td>
                                        <td><%= product.name %></td>
                                        <td><%= Number(product.price).toLocaleString('vi-VN') %> ₫</td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <form action="/products/edit/<%= product.id %>" method="GET">
                                                    <button type="submit" class="btn btn-sm btn-warning">Sửa</button>
                                                </form>

                                                <form action="/products/delete/<%= product.id %>" method="POST" onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">
                                                    <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="p-3 text-center text-muted">
                        Chưa có sản phẩm nào.
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>