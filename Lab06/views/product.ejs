<% const isEdit=!!editProduct; const formTitle=isEdit ? 'Cập nhật sản phẩm' : 'Thêm sản phẩm' ; const submitText=isEdit
    ? 'Cập nhật' : 'Thêm mới' ; const formAction=isEdit ? `/products/update/${editProduct.id}` : '/products' ; const
    p=editProduct || {}; %>

    <!DOCTYPE html>
    <html lang="vi">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Quản lý sản phẩm</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>

    <body class="bg-light">
        <div class="container py-4">
            <h1 class="text-center mb-4">Quản lý sản phẩm</h1>

            <div class="card mb-4">
                <div class="card-header"><strong>
                        <%= formTitle %>
                    </strong></div>
                <div class="card-body">
                    <form action="<%= formAction %>" method="POST" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label" for="name">Tên sản phẩm</label>
                            <input class="form-control" id="name" name="name" type="text" value="<%= p.name || '' %>"
                                required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="price">Giá</label>
                            <input class="form-control" id="price" name="price" type="number"
                                value="<%= p.price || '' %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="unitInStock">Số lượng tồn kho</label>
                            <input class="form-control" id="unitInStock" name="unitInStock" type="number"
                                value="<%= p.unitInStock || '' %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="image">Hình ảnh</label>
                            <input class="form-control" id="image" name="image" type="file" accept="image/*" <%=isEdit
                                ? '' : 'required' %>>
                        </div>

                        <% if (p.image) { %>
                            <div class="mb-3">
                                <p class="mb-2">Hình hiện tại:</p>
                                <img src="<%= p.image %>" alt="<%= p.name %>" class="img-thumbnail"
                                    style="max-width:120px;">
                            </div>
                            <% } %>

                                <button class="btn btn-primary" type="submit">
                                    <%= submitText %>
                                </button>
                                <% if (isEdit) { %>
                                    <a href="/products" class="btn btn-secondary">Hủy</a>
                                    <% } %>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><strong>Danh sách sản phẩm</strong></div>

                <% if (products?.length) { %>
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr class="text-center">
                                    <th>ID</th>
                                    <th>Hình ảnh</th>
                                    <th>Tên sản phẩm</th>
                                    <th>Giá</th>
                                    <th>Số lượng tồn kho</th>
                                    <th style="width:180px">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% products.forEach(p=> { %>
                                    <tr class="text-center">
                                        <td>
                                            <%= p.id %>
                                        </td>
                                        <td>
                                            <% if (p.image) { %>
                                                <img src="<%= p.image %>" alt="<%= p.name %>" class="img-thumbnail"
                                                    style="max-width:80px;">
                                                <% } else { %>
                                                    <span class="text-muted">Không có</span>
                                                    <% } %>
                                        </td>
                                        <td>
                                            <%= p.name %>
                                        </td>
                                        <td>
                                            <%= Number(p.price).toLocaleString('vi-VN') %> ₫
                                        </td>
                                        <td>
                                            <%= p.unitInStock %>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2 justify-content-center">
                                                <a href="/products/<%= p.id %>" class="btn btn-sm btn-info">Chi tiết</a>
                                                <a href="/products/edit/<%= p.id %>"
                                                    class="btn btn-sm btn-warning">Sửa</a>
                                                <form action="/products/delete/<%= p.id %>" method="POST"
                                                    onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">
                                                    <button class="btn btn-sm btn-danger" type="submit">Xóa</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="p-3 text-center text-muted">Chưa có sản phẩm nào.</div>
                        <% } %>
            </div>
        </div>
    </body>

    </html>