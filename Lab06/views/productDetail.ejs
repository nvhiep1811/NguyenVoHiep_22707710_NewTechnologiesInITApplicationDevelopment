<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chi tiết sản phẩm</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="container py-4">
      <h1 class="text-center mb-4">Chi tiết sản phẩm</h1>

      <div class="card mb-4">
        <div class="card-header"><strong><%= product.name %></strong></div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-4 text-center">
              <img
                src="<%= product.image %>"
                alt="<%= product.name %>"
                class="img-fluid img-thumbnail"
              />
            </div>
            <div class="col-md-8">
              <h3><%= product.name %></h3>
              <p>
                <strong>Giá:</strong> <%= product.price.toLocaleString('vi-VN')
                %> đ
              </p>
              <p>
                <strong>Số lượng tồn kho:</strong> <%= product.unitInStock %>
              </p>
              <a href="/products" class="btn btn-secondary">Quay lại</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
